APP_NAME=Neeraj AI OS
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
NEERAJ_API_URL=http://127.0.0.1:8000
NEERAJ_API_TIMEOUT_SECONDS=60

REQUIRE_AUTH=false
DEV_AUTH_BYPASS=true
ENABLE_DEBUG_TRACE=true
ALLOW_TOOL_SIDE_EFFECTS=false

INTERFACE_RATE_LIMIT_WINDOW_SECONDS=60
INTERFACE_RATE_LIMIT_PER_WINDOW=60

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_RESPONSES_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
USE_OPENAI_AGENTS_SDK=true
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-reasoner
MODEL_TIMEOUT_SECONDS=45

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=neeraj_ai_os
MONGODB_EPISODIC_COLLECTION=episodic_memory
MONGODB_TASK_COLLECTION=task_logs

SEMANTIC_BACKEND=in_memory_faiss_compatible
SEMANTIC_TOP_K=6

PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

AUDIT_LOG_FILE=audit.log
